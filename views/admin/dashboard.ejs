<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | Digital Heroes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="#">✨ Digital Heroes - Admin</a>
    <div class="ms-auto">
      <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
  </div>
</nav>

<div class="container mt-4">

  <h2>Admin Dashboard</h2>
  <p class="text-muted">Manage users, draws, charities, and winners.</p>

  <!-- STATS -->
  <div class="row g-4 mb-5">
    <div class="col-md-3">
      <div class="card bg-primary text-white">
        <div class="card-body">
          <h5>Total Users</h5>
          <h2><%= userCount %></h2>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card bg-success text-white">
        <div class="card-body">
          <h5>Prize Pool</h5>
          <h2>₹<%= totalPrizePool %></h2>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card bg-info text-white">
        <div class="card-body">
          <h5>Charity</h5>
          <h2>₹<%= charityTotal %></h2>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card bg-warning">
        <div class="card-body">
          <h5>Total Draws</h5>
          <h2><%= drawsCount %></h2>
        </div>
      </div>
    </div>
  </div>

  <!-- DRAW BUTTON -->
  <div class="mb-4">
    <form action="/admin/run-draw" method="POST">
      <button class="btn btn-primary">🎲 Run Draw</button>
    </form>
  </div>

  <!-- WINNERS TABLE -->
  <div class="card mb-4">
    <div class="card-header bg-primary text-white">
      🏆 Winners List
    </div>

    <div class="card-body p-0">
      <table class="table table-bordered mb-0">
        <thead>
          <tr>
            <th>User</th>
            <th>Draw Info</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>

        <tbody>
          <% if (winners && winners.length) { %>

            <% winners.forEach(w => { %>
              <tr>

                <td>
                  <%= w.users?.name || 'N/A' %><br>
                  <small><%= w.users?.email || '' %></small>
                </td>

                <td>
                  <%= w.draws?.created_at ? new Date(w.draws.created_at).toLocaleDateString() : '-' %><br>

                  <small>
                  Numbers:
<%= w.draws?.result || 'N/A' %>
                  </small>
                </td>

                <td>
                  ₹<%= w.amount %><br>
                  <small>Matched: <%= w.match_count || 0 %></small>
                </td>

                <td>
                  <% if (w.status === 'paid') { %>
                    <span class="badge bg-success">Paid</span>
                  <% } else { %>
                    <span class="badge bg-warning">Pending</span>
                  <% } %>
                </td>

                <td>
                  <% if (w.status !== 'paid') { %>
                    <form action="/admin/verify-payout" method="POST">
                      <input type="hidden" name="winner_id" value="<%= w.id %>">
                      <button class="btn btn-sm btn-success">Mark Paid</button>
                    </form>
                  <% } else { %>
                    <span class="text-muted">Done</span>
                  <% } %>
                </td>

              </tr>
            <% }) %>

          <% } else { %>
            <tr>
              <td colspan="5" class="text-center">No winners yet</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- RECENT DRAWS -->
  <div class="card">
    <div class="card-header bg-dark text-white">
      🎲 Recent Draws
    </div>

    <div class="card-body">
      <% if (draws && draws.length) { %>

        <ul class="list-group">

          <% draws.slice(0,5).forEach(d => { %>
            <li class="list-group-item d-flex justify-content-between">

              <span>
                <%= new Date(d.created_at).toLocaleString() %>
              </span>

              <span class="badge bg-secondary">
                Numbers:
                <%= d.numbers ? d.numbers.join(', ') : 'N/A' %>
              </span>

            </li>
          <% }) %>

        </ul>

      <% } else { %>
        <p class="text-muted">No draws yet</p>
      <% } %>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>