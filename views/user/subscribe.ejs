<!DOCTYPE html>
<html>
<head>
  <title>Subscribe</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container py-5">
  <div class="card mx-auto" style="max-width: 500px;">
    <div class="card-body">
      <h3 class="card-title text-center">Choose Your Plan</h3>
      <form action="/user/subscribe" method="POST">
        <div class="mb-3">
          <label class="form-label">Plan Type</label>
          <select name="plan" class="form-select" required>
            <option value="monthly">Monthly – ₹10/month</option>
            <option value="yearly">Yearly – ₹100/year (Save ₹20)</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary w-100">Subscribe Now</button>
      </form>
      <a href="/user/dashboard" class="btn btn-link w-100 mt-2">Cancel</a>
    </div>
  </div>
</div>
</body>
</html>